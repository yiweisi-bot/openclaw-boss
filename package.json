{
  "name": "openclaw-boss",
  "version": "7.0.0",
  "description": "OpenClaw 老板 v7.0 - 纯 LLM 驱动智能分析！100% 大模型评分，安全元数据模式，通用化设计适配所有 OpenClaw 用户。",
  "author": "Winston & Yiweisi",
  "license": "MIT",
  "homepage": "https://github.com/yiweisi-bot/openclaw-boss",
  "repository": {
    "type": "git",
    "url": "https://github.com/yiweisi-bot/openclaw-boss.git"
  },
  "keywords": [
    "openclaw",
    "skill",
    "boss",
    "profile",
    "analysis",
    "roast",
    "self-reflection"
  ],
  "openclaw": {
    "emoji": "💼",
    "requires": {
      "bins": ["python3"]
    },
    "onload": {
      "script": ".onload",
      "description": "自动配置周报和月报定时任务"
    },
    "features": {
      "scheduledReports": true,
      "weeklyReport": "每周日 22:00",
      "monthlyReport": "每月 1 日 09:00"
    }
  }
}
